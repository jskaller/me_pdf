.env
.DS_Store

# Hermes local runtime state / secrets
hermes/data/.env
hermes/data/sessions/
hermes/data/memories/
hermes/data/logs/
hermes/data/cache/
hermes/data/tmp/

# OpenClaw runtime state must not return
.openclaw/
openclaw.json

# Workspace runtime data
workspace/input/*
!workspace/input/.gitkeep
workspace/jobs/*
!workspace/jobs/.gitkeep
workspace/output/*
!workspace/output/.gitkeep
workspace/archive/*
!workspace/archive/.gitkeep

# Common generated artifacts
*.pyc
__pycache__/
.pytest_cache/

# Hermes runtime directory: keep only placeholder
hermes/data/*
!hermes/.gitkeep

hermes/open-webui/

# Runtime-seeded veraPDF validation profiles; canonical source is /opt/veraPDF-validation-profiles-integration
workspace/assets/validation_profiles/veraPDF-validation-profiles-integration/

# Docker creates app/workspace/ on the host as a root-owned bind-mount point;
# git must never track or try to remove it (breaks stash/clean with EPERM).
app/workspace/
