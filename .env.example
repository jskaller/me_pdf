# NVIDIA NIM / build.nvidia.com
NVIDIA_API_KEY=[nim key nvapi...]
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Validated NVIDIA model IDs
PRIMARY_MODEL=stepfun-ai/step-3.7-flash
VISION_MODEL=meta/llama-4-maverick-17b-128e-instruct

# Hermes service
HERMES_DASHBOARD=1
HERMES_API_BIND=127.0.0.1
HERMES_DASHBOARD_BIND=127.0.0.1
HERMES_API_PORT=8642
HERMES_DASHBOARD_PORT=9119
