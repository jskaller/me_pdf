# Root .env is the human-edited startup/default source of truth.
# Do not add spaces around '='.
# Valid:   NVIDIA_API_KEY=nvapi-...
# Invalid: NVIDIA_API_KEY= nvapi-...

# Provider credentials used by Hermes.
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Startup/default model config. scripts/sync-hermes-env.sh patches
# Hermes /opt/data/config.yaml from these values.
PRIMARY_PROVIDER=nvidia
PRIMARY_MODEL=stepfun-ai/step-3.7-flash
VISION_PROVIDER=nvidia
VISION_MODEL=meta/llama-4-maverick-17b-128e-instruct

# Hermes OpenAI-compatible gateway.
API_SERVER_ENABLED=true
API_SERVER_HOST=0.0.0.0
API_SERVER_PORT=8642
API_SERVER_KEY=change-me-local-hermes-token
API_SERVER_MODEL_NAME="Hermes Agent"

# Open WebUI talks to Hermes as an OpenAI-compatible endpoint.
# This is the same local gateway token as API_SERVER_KEY, not an OpenAI account key.
OPENAI_API_KEY=change-me-local-hermes-token
OPENAI_API_BASE_URL=http://hermes:8642/v1

# Hermes admin dashboard.
HERMES_DASHBOARD=1
HERMES_DASHBOARD_HOST=0.0.0.0
HERMES_DASHBOARD_PORT=9119
HERMES_DASHBOARD_INSECURE=1
GATEWAY_ALLOW_ALL_USERS=true

# Host port bindings.
HERMES_API_BIND=127.0.0.1
HERMES_API_PORT=8642
HERMES_DASHBOARD_BIND=127.0.0.1
OPEN_WEBUI_BIND=127.0.0.1
OPEN_WEBUI_PORT=8080

# Open WebUI behavior.
OPEN_WEBUI_AUTH=false
WEBUI_AUTH=false
ENABLE_TITLE_GENERATION=false
ENABLE_FOLLOW_UP_GENERATION=false
ENABLE_TAGS_GENERATION=false

# PDF pipeline model-dependent tools.
# Default: call Hermes gateway so admin-console runtime changes are honored.
# Debug only: set VISION_TOOLS_MODE=provider to call provider APIs directly.
VISION_TOOLS_MODE=hermes
VISION_TOOLS_DEBUG=false
VISION_PROVIDER_TIMEOUT=120
VISION_PROVIDER_RETRIES=1

# Hermes approval mode: MUST be 'auto' for unattended API-server/WebUI operation.
# Default 'manual' blocks every terminal command on a human-approval gate that
# the WebUI path never answers, silently stalling jobs at the first command.
# Set live with: docker exec <container> hermes config set approvals.mode auto
# (tirith risk assessment remains active via security.tirith_enabled: true)
