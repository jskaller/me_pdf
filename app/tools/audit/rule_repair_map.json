{
  "_meta": {
    "version": "2.0.0",
    "standard": "PDF/UA-1 (ISO 14289-1)",
    "purpose": "Maps veraPDF rule IDs to ordered repair strategies. The orchestrator looks up each failing rule ID here, sorts strategies by pass_rate desc / pass_count desc / doc_tag_overlap desc, and tries them in order. If all strategies fail or strategies array is empty, Hermes is invoked to write a new script.",
    "key_format": "{normalised_spec}/{clause}  e.g. PDF/UA-1/7.18.6.3",
    "normalisation": "veraPDF Greenfield profiles output rule IDs normalised to PDF/UA-1 prefix by parse_verapdf_summary.py.",
    "schema_version_notes": "v2.0.0 — flat repair_script replaced by strategies array. Each rule has manual:true/false flag. manual:true routes directly to Hermes. Strategies sorted by pass_rate desc, pass_count desc, doc_tag_overlap desc before execution.",
    "confidence_levels": {
      "CONFIRMED": "Verified on at least one real Montefiore job — outcome was PASS",
      "EXPECTED": "Correct per ISO 14289-1 spec + veraPDF rule definitions — not yet confirmed on a Montefiore job",
      "NEW": "Written by Hermes — pass_count < 2, treat with extra scrutiny"
    },
    "strategy_ordering": "Sort strategies by: (1) pass_rate descending, (2) pass_count descending as tiebreaker, (3) doc_tag_overlap_score descending as final tiebreaker. Never exclude a strategy based on doc type — doc type affects ordering only, not eligibility. Skip strategies whose known_failure_modes match the current document's observed failure reason.",
    "hermes_triggers": "The orchestrator emits an HERMES_REQUIRED signal when: (a) manual:true and strategies is empty, (b) all strategies exhausted with no PASS, (c) rule_id not found in map at all (unknown_rule). The signal includes rule_id, description, all strategy attempt history with failure reasons, and document tags. The agent reads the signal and either writes a new script or escalates to the operator if automation is not possible. For unknown rules, the agent researches the rule before writing.",
    "repair_order_note": "repair_order within each strategy matches the mandatory sequence. fix_table_headers.py (order 10) MUST be last — no saves may occur after it. fix_table_tagging.py (order 9) MUST run before fix_table_headers.py.",
    "confirmed_jobs": 7,
    "last_updated": "2026-05-28"
  },
